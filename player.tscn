[sub_resource type="GDScript" id="GDScript_uuxst"]
script/source = "extends Node2D

@export var camera: Camera2D

var intensity := 0.0
var current_tween: Tween

func shake(amount: float, duration: float):
	if current_tween: current_tween.stop()
	intensity = amount

	current_tween = get_tree().create_tween().set_ease(Tween.EASE_OUT)
	current_tween.tween_property(self, \"intensity\", 0, duration)

func _process(delta: float) -> void:
	camera.offset = Vector2.UP.rotated(randf_range(0, PI * 2)) * intensity
"

